{
	"compilerOptions": {
		"target": "es2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"outDir": "."
	},
	"exclude": ["node_modules", "client", "public/assets", "vite.config.ts"],
	"include": ["server.ts", "serverHelpers.ts", "logStreamer.ts", "passwordPolicy.ts", "shared/**/*.ts"]
}
